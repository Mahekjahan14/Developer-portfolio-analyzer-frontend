{
  "name": "developer-portfolio-analyzer",
  "version": "1.0.0",
  "description": "Full-stack developer portfolio analyzer",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start": "npm run start:frontend",
    "start:frontend": "cd portfolio-analyzer-frontend && npm start",
    "start:backend": "mvn spring-boot:run",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:frontend": "cd portfolio-analyzer-frontend && npm run build",
    "install:all": "npm install && cd portfolio-analyzer-frontend && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
